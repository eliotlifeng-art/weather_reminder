#:kivy 2.2.0

<WeatherCard>:
    elevation: 3
    radius: [12]
    size_hint_y: None
    height: dp(200)
    padding: dp(16)
    spacing: dp(8)
    orientation: "vertical"

<AdviceCard>:
    elevation: 1
    radius: [8]
    size_hint_y: None
    height: dp(56)
    padding: [dp(12), dp(8)]
    spacing: dp(12)
    orientation: "horizontal"
